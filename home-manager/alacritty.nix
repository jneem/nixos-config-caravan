 {
  programs.alacritty = {
    enable = true;
    settings = {
      window.decorations = "none";
      font = {
        normal = {
          family = "Lotion";
          style = "Regular";
        };

        bold = {
          family = "Lotion";
          style = "Bold";
        };

        italic = {
          family = "Lotion";
          style = "Italic";
        };

        bold_italic = {
          family = "Lotion";
          style = "Bold Italic";
        };

        size = 16;
      };
    };
  };
}
